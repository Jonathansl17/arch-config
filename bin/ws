#!/bin/bash
GREEN='\033[0;32m'; YELLOW='\033[1;33m'; CYAN='\033[0;36m'; NC='\033[0m'
eth=$(nmcli -t -f NAME,TYPE connection show --active | awk -F: '$2 ~ /ethernet/ {print $1; exit}')
wifi=$(nmcli -t -f NAME,TYPE connection show --active | awk -F: '$2 ~ /wireless/ {print $1; exit}')
echo -e "${CYAN}=== Wifi Status ===${NC}"
if [[ -n "$eth" ]]; then echo -e "  LAN:  ${GREEN}Connected${NC} → ${GREEN}$eth${NC}"
else echo -e "  LAN:  ${YELLOW}Disconnected${NC}"; fi
if [[ -n "$wifi" ]]; then echo -e "  WiFi: ${GREEN}Connected${NC} → ${GREEN}$wifi${NC}"
else echo -e "  WiFi: ${YELLOW}Disconnected${NC}"; fi
