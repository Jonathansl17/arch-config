#
# ~/.bashrc
#

# If not running interactively, don't do anything
[[ $- != *i* ]] && return

alias ls='ls --color=auto'
alias la='ls -ldA --color=auto .[!.]* ..?* 2>/dev/null'
alias grep='grep --color=auto'
PS1='[\u@\h \[\033[1;96m\]\W\[\033[0m\]]\$ '
stty intr ^Z
stty susp ^C
alias pgadmin4="setsid -f /usr/pgadmin4/bin/pgadmin4 >/dev/null 2>&1"
alias postman="setsid -f postman >/dev/null 2>&1"
alias idea="setsid -f idea >/dev/null 2>&1"
alias code="setsid -f code >/dev/null 2>&1"
alias brave="setsid -f brave >/dev/null 2>&1"
alias pcmanfm="setsid -f pcmanfm >/dev/null 2>&1"
alias discord="setsid -f discord >/dev/null 2>&1"
alias telegram="setsid -f Telegram >/dev/null 2>&1"
alias obs="setsid -f obs >/dev/null 2>&1"
alias what="setsid -f /opt/brave-bin/brave --profile-directory=Default --app-id=hnpfjngllnobngcgfapefoaidbinmjnm >/dev/null 2>&1"
alias spot="setsid -f /opt/brave-bin/brave --profile-directory=Default --app-id=pjibgclleladliembfgfagdaldikeohf >/dev/null 2>&1"
alias o="sudo systemctl poweroff -i"
alias u='sudo pacman -Syu && yay -Syu'
alias s='git add . && MSG=$(git diff --cached | claude -p "Generate a concise commit message in English for these changes. Respond ONLY with the commit message itself, in English. Do NOT add any author, co-author, signature, attribution, trailers, or mention of Claude/Anthropic/AI.") && git commit -m "$MSG" && git push'
#alias s='git add . && git commit -m "Updates" && git push origin master'
alias b='echo "$(cat /sys/class/power_supply/BAT1/capacity)% — $(cat /sys/class/power_supply/BAT1/status)"'
alias d='date'
alias ram='$HOME/bin/ram'
alias x='d && b && t'

export PATH="$HOME/.local/bin:$PATH"

# === Android / Java toolchain ===
export JAVA_HOME=/usr/lib/jvm/java-21-openjdk
export ANDROID_HOME=/opt/android-sdk
export ANDROID_SDK_ROOT=$ANDROID_HOME
export PATH=$PATH:$JAVA_HOME/bin:$ANDROID_HOME/cmdline-tools/latest/bin:$ANDROID_HOME/platform-tools:$ANDROID_HOME/build-tools/34.0.0



# === network ===
alias wifi='bash /wifi/wifi.sh'

# === GUI launcher functions ===
xournalpp() {
    for arg in "$@"; do
        case "$arg" in
            -*) ;;
            *.xopp) [ -e "$arg" ] || cp ~/templates/template.xopp "$arg" ;;
        esac
    done
    setsid -f /usr/bin/xournalpp "$@" >/dev/null 2>&1
}

libreoffice() {
    setsid -f /usr/bin/libreoffice "$@" >/dev/null 2>&1
}

evince() {
    setsid -f /usr/bin/evince "$@" >/dev/null 2>&1
}

vlc() {
    setsid -f /usr/bin/vlc "$@" >/dev/null 2>&1
}

# === nvm (Node Version Manager) — lazy load ===
# Stubs cargan nvm/node/npm/npx/corepack on-demand. Ahorra ~48ms por shell.
export NVM_DIR="$HOME/.nvm"
_nvm_load() {
    unset -f nvm node npm npx corepack
    [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
    [ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"
}
nvm()      { _nvm_load; nvm "$@"; }
node()     { _nvm_load; node "$@"; }
npm()      { _nvm_load; npm "$@"; }
npx()      { _nvm_load; npx "$@"; }
corepack() { _nvm_load; corepack "$@"; }

# === local overrides (NOT VERSIONED) ===
# ~/.bashrc.local is for aliases/variables with credentials, tokens
# or anything machine-specific that must not travel with the repo.
# If it doesn't exist nothing happens — this block is optional.
[ -f "$HOME/.bashrc.local" ] && . "$HOME/.bashrc.local"

# === termclip configuration ===
# Ensure ~/bin is on PATH so termclip scripts (c, cc, cpwd, v) are found.
case ":$PATH:" in
  *":$HOME/bin:"*) ;;
  *) export PATH="$HOME/bin:$PATH" ;;
esac
# === end termclip ===

# pnpm
export PNPM_HOME="/home/jony/.local/share/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac
# pnpm end
export CHROME_BIN=/usr/bin/brave

