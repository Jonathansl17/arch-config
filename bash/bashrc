# === GUI launcher functions ===
xournalpp() {
    for arg in "$@"; do
        case "$arg" in
            -*) ;;
            *.xopp) [ -e "$arg" ] || cp ~/templates/template.xopp "$arg" ;;
        esac
    done
    setsid -f /usr/bin/xournalpp "$@" >/dev/null 2>&1
}

libreoffice() {
    setsid -f /usr/bin/libreoffice "$@" >/dev/null 2>&1
}

evince() {
    setsid -f /usr/bin/evince "$@" >/dev/null 2>&1
}

xp() {
    if [ $# -eq 0 ]; then
        echo "uso: xp archivo.xopp [archivo2.xopp ...]" >&2
        return 1
    fi
    for f in "$@"; do
        if [ ! -e "$f" ]; then


            echo "xp: no existe '$f'" >&2
            continue
        fi
        /usr/bin/xournalpp --create-pdf "${f%.*}.pdf" "$f"
    done
}

