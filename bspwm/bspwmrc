#! /bin/sh

pgrep -x sxhkd > /dev/null || sxhkd &

xsetroot -cursor_name left_ptr

# Monitors: enables HDMI-1-1 to the right of eDP when connected.
if xrandr --query | grep -q "^HDMI-1-1 connected"; then
    # Max refresh rate on external monitor
    max_rate=$(xrandr | sed -n '/^HDMI-1-1 connected/,/^[^ ]/{/^ /p}' \
        | head -1 | grep -oP '[0-9]+\.[0-9]+' \
        | sort -t. -k1,1nr -k2,2nr | head -1)
    xrandr --output eDP --primary --auto \
           --output HDMI-1-1 --auto --right-of eDP \
           ${max_rate:+--rate "$max_rate"}
    bspc monitor eDP      -d I II III IV V       # laptop: super+1..5
    bspc monitor HDMI-1-1 -d VI VII VIII IX X    # external: super+6..0 (0 = X)
else
    bspc monitor -d I II III IV V VI VII VIII IX X  # no HDMI: all 10 on eDP
fi

bspc config presel_feedback      false

bspc config focused_border_color "#FFFFFF"

# Terminals launched via the split keybinds
bspc rule -a split_term state=tiled layer=normal

# Main apps: tiled + follow + focus
bspc rule -a Code            follow=on focus=on
bspc rule -a code-oss        follow=on focus=on
bspc rule -a Code-oss        follow=on focus=on
bspc rule -a jetbrains-idea  follow=on focus=on
bspc rule -a jetbrains-idea-ce follow=on focus=on
bspc rule -a pgAdmin4        follow=on focus=on
bspc rule -a Postman         follow=on focus=on
bspc rule -a Thunar          follow=on focus=on
bspc rule -a Brave-browser   follow=on focus=on

# LEMONBAR-START
/lemonbar/watcher.sh &
# LEMONBAR-END
